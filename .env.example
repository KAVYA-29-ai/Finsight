# App ports (for local development only)
PHONEPE_PORT=3000
FINSIGHT_PORT=3001

# App state
FINSIGHT_SOURCE_LABEL=shared-phonepe-state

# Deployed API URLs (for local frontend to call backend services)
# Use http://localhost:3000 locally, Railway URL in production
PHONEPE_API_URL=http://localhost:3000
FINSIGHT_API_URL=http://localhost:3001

# Vite env vars (for frontend build-time injection on Vercel)
VITE_API_URL=
VITE_PHONEPE_API_URL=http://localhost:3000
VITE_FINSIGHT_API_URL=http://localhost:3001

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=