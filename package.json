{
  "name": "finsight2-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "phonepe",
    "finsight"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w phonepe\" \"npm run dev -w finsight\"",
    "dev:phonepe": "npm run dev -w phonepe",
    "dev:finsight": "npm run dev -w finsight",
    "finsight": "npm run dev:finsight",
    "build": "npm run build -w phonepe && npm run build -w finsight",
    "seed:firebase": "node scripts/firebase-seed.mjs",
    "check:firebase": "node scripts/firebase-query-check.mjs",
    "supabase:sql": "cat scripts/supabase/schema_and_seed.sql",
    "supabase:health": "node -e \"import('./shared/supabase.js').then(async (m)=>{console.log(await m.getSupabaseHealthSnapshot());}).catch((e)=>{console.error(e.message);process.exit(1);});\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.4.7",
    "firebase-admin": "^12.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
